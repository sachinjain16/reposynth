# Choose: openrouter, ollama, or openai-compatible
LLM_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# LM Studio, LocalAI, llama.cpp server, vLLM, or another OpenAI-compatible server
OPENAI_COMPAT_BASE_URL=http://localhost:1234/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=local-model

GITHUB_TOKEN=ghp_optional_for_higher_rate_limits
NEXT_PUBLIC_APP_URL=http://localhost:3000
